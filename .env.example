# Socratink terminal dogfood env
#
# Copy this file to:
#   scripts/socratink_tui/.env
#
# Keep the real .env local. It is ignored by git.

GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash

# Optional:
# LLM_PROVIDER=gemini                    # gemini (default) or openai_compatible (LM Studio)
# LLM_BASE_URL=http://127.0.0.1:1234/v1 # required when LLM_PROVIDER=openai_compatible
# LLM_API_KEY=lm-studio                 # LM Studio accepts any non-empty key
# LLM_REQUEST_TIMEOUT_SECONDS=120     # local models are slow; default 120s
# SOCRATINK_TUI_LOG_ROOT=.qa-runs/socratink-tui

# Hosted loop server (./socratink-loop-server → http://127.0.0.1:8787/loop)
# PORT=8787
# LOOP_APP_VERSION=          # optional; default is lib/loop-server/version.mjs
# SOCRATINK_LOOP_API_KEY=           # if set, /api/* requires Authorization: Bearer …
# SOCRATINK_TUI_FAKE_LLM=1          # sandbox without Gemini spend
# SOCRATINK_LAB_ENABLED=1           # founder lab at http://127.0.0.1:8787/lab (localhost only)
# SOCRATINK_LOOP_ALLOW_MODEL_OVERRIDE=1  # llm pill model picker; localhost dogfood only

# Persona (mock student) — loop-persona-live.mjs / run-substrate-persona-matrix.mjs
# PERSONA_LLM_PROVIDER=openai_compatible   # gemini (default) or openai_compatible (LM Studio)
# PERSONA_LLM_BASE_URL=http://127.0.0.1:1234/v1
# PERSONA_LLM_MODEL=google/gemma-4-12b
# PERSONA_LLM_API_KEY=lm-studio            # LM Studio accepts any non-empty key

# /feedback → your Gmail (free Google Apps Script — see deploy/FEEDBACK-GMAIL.md)
# SOCRATINK_FEEDBACK_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# SOCRATINK_FEEDBACK_SECRET=long-random-string
# SOCRATINK_FEEDBACK_TO=you@gmail.com
