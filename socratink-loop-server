#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"
ENV_FILE="${SOCRATINK_TUI_ENV_FILE:-.env}"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck source=/dev/null
  . "$ENV_FILE"
  set +a
fi
# Stale shell exports should not silently keep sandbox mode when .env is live.
if [[ ! -f "$ENV_FILE" ]] || ! grep -qE '^[[:space:]]*SOCRATINK_TUI_FAKE_LLM=1[[:space:]]*$' "$ENV_FILE"; then
  unset SOCRATINK_TUI_FAKE_LLM
fi

export PORT="${PORT:-8787}"
existing_pids="$(lsof -ti "tcp:${PORT}" 2>/dev/null || true)"
if [[ -n "$existing_pids" ]]; then
  echo "[socratink-loop-server] stopping existing listener(s) on port ${PORT}: ${existing_pids//$'\n'/ }"
  # shellcheck disable=SC2086
  kill $existing_pids 2>/dev/null || true
  for _ in {1..30}; do
    if ! lsof -ti "tcp:${PORT}" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
  if lsof -ti "tcp:${PORT}" >/dev/null 2>&1; then
    echo "[socratink-loop-server] port ${PORT} still in use; try: lsof -i :${PORT}" >&2
    exit 1
  fi
fi

exec node --no-warnings loop-server.mjs
