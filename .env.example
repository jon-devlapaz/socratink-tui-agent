# Socratink founder lab env
#
# Copy to .env. Prefer ./socratink start and /lab controls for day-to-day runs.
#
# Keep the real .env local. It is ignored by git.

# Cloud Gemini enables live tutor runs and cloud mock-student runs.
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash

# LM Studio remains the local-model option in Founder Console.
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_API_KEY=lm-studio
# LM_STUDIO_MODEL=google/gemma-4-12b

# FreeLLMAPI OpenAI-compatible endpoint. This is the only Founder Console "router" pipe.
# LLM_ROUTER_BASE_URL=http://100.79.25.11:3001/v1
# LLM_ROUTER_API_KEY=
# LLM_OPENAI_COMPAT_MODEL=auto
# LLM_REQUEST_TIMEOUT_SECONDS=120

# Optional mock-student override. Defaults to the selected LM Studio/router config.
# PERSONA_LLM_BASE_URL=http://127.0.0.1:1234/v1
# PERSONA_LLM_API_KEY=lm-studio
# PERSONA_LLM_MODEL=auto

# /feedback → your Gmail (free Google Apps Script — see deploy/FEEDBACK-GMAIL.md)
# SOCRATINK_FEEDBACK_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# SOCRATINK_FEEDBACK_SECRET=long-random-string
# SOCRATINK_FEEDBACK_TO=you@gmail.com

# Advanced/test/deploy knobs intentionally omitted from founder setup:
# PORT, LOOP_APP_VERSION, SOCRATINK_LOOP_API_KEY, SOCRATINK_TUI_LOG_ROOT,
# SOCRATINK_TUI_FAKE_LLM, SOCRATINK_TUI_FAKE_* classification overrides,
# SOCRATINK_LAB_ENABLED, SOCRATINK_LOOP_ALLOW_MODEL_OVERRIDE.
# See AGENTS.md and HARNESS-TRACEABILITY.md when working on tests or deploys.
