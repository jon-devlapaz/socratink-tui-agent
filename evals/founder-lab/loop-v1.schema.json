{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socratink.local/evals/founder-lab/loop-v1.schema.json",
  "title": "Founder Lab Loop Rubric v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rubric_version",
    "overall",
    "axes",
    "summary",
    "recommendations"
  ],
  "properties": {
    "rubric_version": {
      "const": "loop-v1"
    },
    "overall": {
      "$ref": "#/$defs/score"
    },
    "axes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "substrate_viability",
        "generation_before_recognition",
        "repair_load",
        "evidence_progression",
        "model_reliability",
        "prompt_adjustment_signal"
      ],
      "properties": {
        "substrate_viability": {
          "$ref": "#/$defs/axis"
        },
        "generation_before_recognition": {
          "$ref": "#/$defs/axis"
        },
        "repair_load": {
          "$ref": "#/$defs/axis"
        },
        "evidence_progression": {
          "$ref": "#/$defs/axis"
        },
        "model_reliability": {
          "$ref": "#/$defs/axis"
        },
        "prompt_adjustment_signal": {
          "$ref": "#/$defs/axis"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pass",
        "watch",
        "fail"
      ],
      "properties": {
        "pass": {
          "type": "integer",
          "minimum": 0
        },
        "watch": {
          "type": "integer",
          "minimum": 0
        },
        "fail": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "score": {
      "enum": [
        "pass",
        "watch",
        "fail"
      ]
    },
    "axis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "evidence"
      ],
      "properties": {
        "score": {
          "$ref": "#/$defs/score"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
